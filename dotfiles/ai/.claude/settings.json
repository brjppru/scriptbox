{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "permissions": {
    "allow": [
      "Bash(ssh -i /Users/brjed/.grzegorz/id_ossh_grzegorz.priv *)",
      "Bash(ssh -i ~/.grzegorz/id_ossh_grzegorz.priv *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /Users/brjed/.claude/sound/msg.wav"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /Users/brjed/.claude/sound/oncoming.wav"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/brjed/.claude/statusline-command.sh"
  },
  "spinnerTipsEnabled": false,
  "tui": "fullscreen",
  "verbose": true,
  "skipAutoPermissionPrompt": true
}
